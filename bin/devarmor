#!/usr/bin/env python3
"""
DevArmor CLI Installer and Updater

Self-installing Python script that:
1. Installs devarmor-core from the Hoad Python Packages index
2. Keeps itself updated
3. Provides version management
"""

import sys
import subprocess
import json
import os
from pathlib import Path
from typing import Optional

PACKAGE_INDEX = "https://hoad-org.github.io/python-packages"
PACKAGE_NAME = "devarmor-core"
DEFAULT_VERSION = ">=0.1.0"


def get_installed_version() -> Optional[str]:
    """Get the currently installed version of devarmor-core."""
    try:
        result = subprocess.run(
            [sys.executable, "-m", "pip", "show", PACKAGE_NAME],
            capture_output=True,
            text=True,
            check=True,
        )
        for line in result.stdout.split("\n"):
            if line.startswith("Version:"):
                return line.split(":", 1)[1].strip()
    except subprocess.CalledProcessError:
        return None


def get_latest_version() -> Optional[str]:
    """Get the latest available version from the package index."""
    try:
        import urllib.request
        import html.parser

        class VersionExtractor(html.parser.HTMLParser):
            def __init__(self) -> None:
                super().__init__()
                self.versions = []

            def handle_starttag(self, tag: str, attrs):  # type: ignore
                if tag == "a":
                    for attr, value in attrs:
                        if attr == "href" and "devarmor" in value:
                            # Extract version from filename
                            if ".whl" in value or ".tar.gz" in value:
                                parts = value.split("/")[-1].split("-")
                                if len(parts) >= 2:
                                    version = parts[1]
                                    if version not in self.versions:
                                        self.versions.append(version)

        url = f"{PACKAGE_INDEX}/simple/{PACKAGE_NAME.lower().replace('_', '-')}/"
        with urllib.request.urlopen(url) as response:
            content = response.read().decode("utf-8")
            parser = VersionExtractor()
            parser.feed(content)
            if parser.versions:
                # Return the first (latest) version found
                return sorted(parser.versions, reverse=True)[0]
    except Exception:
        return None


def install_package(version: str = DEFAULT_VERSION) -> bool:
    """Install or upgrade devarmor-core."""
    try:
        print(f"Installing {PACKAGE_NAME}=={version}...")
        subprocess.run(
            [
                sys.executable,
                "-m",
                "pip",
                "install",
                "--index-url",
                PACKAGE_INDEX,
                f"{PACKAGE_NAME}{version}",
                "--upgrade",
            ],
            check=True,
        )
        print(f"✓ {PACKAGE_NAME} installed successfully")
        return True
    except subprocess.CalledProcessError as e:
        print(f"✗ Failed to install {PACKAGE_NAME}: {e}")
        return False


def check_for_updates() -> bool:
    """Check if a newer version is available."""
    current = get_installed_version()
    latest = get_latest_version()

    if not current:
        print(f"⚠ {PACKAGE_NAME} not installed")
        return False

    if not latest:
        print(f"⚠ Could not check for updates (network error)")
        return False

    if current != latest:
        print(f"Update available: {current} → {latest}")
        return True

    print(f"✓ {PACKAGE_NAME} is up to date ({current})")
    return False


def main() -> int:
    """Main CLI entry point."""
    if len(sys.argv) < 2:
        print("DevArmor CLI Installer")
        print("")
        print("Usage: devarmor <command>")
        print("")
        print("Commands:")
        print("  install      Install devarmor-core")
        print("  upgrade      Upgrade to the latest version")
        print("  version      Show installed version")
        print("  latest       Show latest available version")
        print("  check        Check for updates")
        print("  help         Show this help message")
        return 0

    command = sys.argv[1]

    if command == "install":
        return 0 if install_package() else 1

    elif command == "upgrade":
        version = sys.argv[2] if len(sys.argv) > 2 else DEFAULT_VERSION
        return 0 if install_package(version) else 1

    elif command == "version":
        version = get_installed_version()
        if version:
            print(f"{PACKAGE_NAME} {version}")
            return 0
        else:
            print(f"{PACKAGE_NAME} is not installed")
            return 1

    elif command == "latest":
        version = get_latest_version()
        if version:
            print(f"{PACKAGE_NAME} {version}")
            return 0
        else:
            print("Could not determine latest version")
            return 1

    elif command == "check":
        return 0 if not check_for_updates() else 1

    elif command in ("help", "-h", "--help"):
        print("DevArmor CLI Installer")
        print("")
        print("Commands:")
        print("  install      Install devarmor-core")
        print("  upgrade      Upgrade to the latest version")
        print("  version      Show installed version")
        print("  latest       Show latest available version")
        print("  check        Check for updates")
        return 0

    else:
        print(f"Unknown command: {command}")
        print("Use 'devarmor help' for usage information")
        return 1


if __name__ == "__main__":
    sys.exit(main())
